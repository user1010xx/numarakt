# Railway Variables / local .env — gerçek değerleri buraya YAZMAYIN
# Bu dosya sadece isim şablonudur.

# Zorunlu
TELEGRAM_BOT_TOKEN=
TONIVA_API_KEY=

# Opsiyonel (varsayılan: production public API)
TONIVA_BASE_URL=https://crm.toniva.net/api/public/v1

# Opsiyonel: sadece bu Telegram gruplarında çalışsın (virgülle)
# ALLOWED_CHAT_IDS=

# Zaman dilimi (son 30 gün hesabı)
TZ=Europe/Istanbul
